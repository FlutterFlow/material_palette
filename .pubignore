# The published package is intentionally minimal: lib/ (code + shader
# assets), README, CHANGELOG, LICENSE, pubspec.yaml. Everything else —
# demo apps, benchmarking/profiling artifacts, dev config — stays in the
# repo only. Verify with: dart pub publish --dry-run

# Internal test/demo app (not part of the published package)
test/

